{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/privacy", "destination": "/legal/privacy", "permanent": true }
  ],
  "headers": [
    { "source": "/legal", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }] },
    { "source": "/legal/:path*", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }] }
  ]
}
